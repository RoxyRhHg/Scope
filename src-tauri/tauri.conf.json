{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scope Buffett",
  "version": "0.1.0",
  "identifier": "com.scope.buffett",
  "build": {
    "beforeDevCommand": "npm start",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Scope Buffett",
        "width": 1600,
        "height": 1040,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
